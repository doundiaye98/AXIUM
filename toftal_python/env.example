# Renommez en .env (sans .txt) à côté de app.py, ou placez .env dans le dossier parent AXIUM.
# Ne commitez jamais .env.

OPENAI_API_KEY=

# Sans OPENAI_API_KEY, l’assistant local est déjà actif par défaut.
# Pour afficher uniquement « configurez la clé API » sans mode local :
# AXIUM_CHAT_LOCAL=0

# Optionnel :
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
